# Template environment file.
# Copy to .env and fill values locally.

# -----------------------------
# Application Runtime
# -----------------------------
PYTHON_TEMPLATE_HOST=127.0.0.1
PYTHON_TEMPLATE_PORT=8000

# -----------------------------
# Logging
# -----------------------------
# Log level: debug, info, warning, error, critical
PYTHON_TEMPLATE_LOG_LEVEL=info

# Log format: json (production) or pretty (development)
PYTHON_TEMPLATE_LOG_FORMAT=pretty

# -----------------------------
# Debugger (Docker dev only)
# -----------------------------
# When enabled, the server will expose debugpy for IDE attach.
PYTHON_TEMPLATE_DEBUGPY=0
PYTHON_TEMPLATE_DEBUGPY_HOST=0.0.0.0
PYTHON_TEMPLATE_DEBUGPY_PORT=5678
# Set to 1 to wait for debugger to attach before starting
PYTHON_TEMPLATE_DEBUGPY_WAIT=0

# -----------------------------
# Docker Compose (optional)
# -----------------------------
# Published ports on host
PYTHON_TEMPLATE_PORT_PUBLISH=8000
PYTHON_TEMPLATE_DEBUGPY_PORT_PUBLISH=5678